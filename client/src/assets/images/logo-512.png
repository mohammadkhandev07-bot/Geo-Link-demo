<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <defs>
    <linearGradient id="logoGrad512" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3B82F6"/>
      <stop offset="50%" stop-color="#8B5CF6"/>
      <stop offset="100%" stop-color="#EC4899"/>
    </linearGradient>
    <linearGradient id="orbitGrad512" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#60A5FA"/>
      <stop offset="100%" stop-color="#F472B6"/>
    </linearGradient>
    <filter id="glow512">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" rx="128" fill="#0F172A"/>
  
  <!-- Main A Shape -->
  <path d="M256 80 L410 400 H350 L310 300 H202 L162 400 H102 L256 80 Z" 
        fill="url(#logoGrad512)" 
        stroke="white" 
        stroke-width="4"
        filter="url(#glow512)"/>
  
  <!-- Inner Triangle -->
  <path d="M256 180 L286 260 H226 L256 180 Z" fill="rgba(255,255,255,0.3)"/>
  
  <!-- Orbit -->
  <ellipse cx="256" cy="280" rx="200" ry="60" 
           fill="none" 
           stroke="url(#orbitGrad512)" 
           stroke-width="12" 
           stroke-linecap="round"
           transform="rotate(-25 256 280)"/>
  
  <!-- Center Dot -->
  <circle cx="256" cy="260" r="15" fill="white"/>
</svg>
